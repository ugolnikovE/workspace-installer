PLUGIN_DIR="$CONFIG_DIR/plugins"

##### Bar Appearance #####
sketchybar --bar position=top height=32 blur_radius=30 color=0x40000000 topmost=on

##### Defaults #####
default=(
  padding_left=2
  padding_right=2
  icon.font="Hack Nerd Font Mono:Bold:30.0"
  label.font="Hack Nerd Font Mono:Bold:13.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=2
  icon.padding_right=2
  label.padding_left=2
  label.padding_right=2
)
sketchybar --default "${default[@]}"

##### Workspaces (left) #####
for sid in 1 2; do
  sketchybar --add item workspace."$sid" left \
             --set workspace."$sid" \
                   icon="$sid" \
                   icon.padding_left=7 \
                   icon.padding_right=7 \
                   icon.font="Hack Nerd Font Mono:Bold:13.0" \
                   background.color=0x00ffffff \
                   background.corner_radius=5 \
                   background.height=25 \
                   label.drawing=off \
                   script="$PLUGIN_DIR/workspace.sh" \
                   click_script="aerospace workspace $sid"
done

# Update workspaces
sketchybar --add event aerospace_workspace_change
for sid in 1 2; do
  sketchybar --subscribe workspace."$sid" aerospace_workspace_change
done

##### Right Items (right-to-left order) #####
# Separator defaults
SEP=(
  icon="│"
  icon.font="Hack Nerd Font Mono:Bold:13.0"
  icon.color=0x50ffffff
  label.drawing=off
  icon.padding_left=6
  icon.padding_right=6
)

sketchybar --add item clock right \
           --set clock update_freq=10 script="$PLUGIN_DIR/clock.sh" \
                                                                     \
           --add item sep_kb right \
           --set sep_kb "${SEP[@]}" \
                                     \
           --add item keyboard right \
           --set keyboard update_freq=1 \
                          icon.font="Hack Nerd Font Mono:Bold:13.0" \
                          script="$PLUGIN_DIR/keyboard.sh" \
                                                            \
           --add item sep1 right \
           --set sep1 "${SEP[@]}" \
                                   \
           --add item wifi right \
           --set wifi update_freq=5 script="$PLUGIN_DIR/wifi.sh" \
                      click_script="open x-apple.systempreferences:com.apple.preference.network" \
                                                                  \
           --add item sep2 right \
           --set sep2 "${SEP[@]}" \
                                   \
           --add item bluetooth right \
           --set bluetooth update_freq=5 script="$PLUGIN_DIR/bluetooth.sh" \
                           click_script="open x-apple.systempreferences:com.apple.BluetoothSettings" \
                                                                            \
           --add item sep3 right \
           --set sep3 "${SEP[@]}" \
                                   \
           --add item battery right \
           --set battery update_freq=60 script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change \
                                                                \
           --add item sep4 right \
           --set sep4 "${SEP[@]}" \
                                   \
           --add item ram right \
           --set ram update_freq=5 \
                     script="$PLUGIN_DIR/ram.sh" \
                                                  \
           --add item sep5 right \
           --set sep5 "${SEP[@]}" \
                                   \
           --add item cpu right \
           --set cpu update_freq=5 \
                     script="$PLUGIN_DIR/cpu.sh"

sketchybar --update
